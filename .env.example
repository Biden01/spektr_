# PostgreSQL
POSTGRES_USER=spektr
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=spektr

# App — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_ME

LOG_LEVEL=INFO
HTTP_PORT=80

# CORS — set to your real domain
CORS_ORIGINS=https://yourdomain.com

# Token TTL
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Workers (uvicorn)
WORKERS=2
